{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caizefan34.github.io/3dgs-renderer-benchmark/benchmark/schemas/training-result.schema.json",
  "title": "3DGS native training result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "evidence_tier", "track", "backend", "case", "budget", "performance", "artifact", "quality", "provenance"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "status": {"enum": ["complete", "failed"]},
    "evidence_tier": {"const": "measured"},
    "track": {"const": "native_training"},
    "backend": {"type": "object"},
    "case": {"type": "object"},
    "budget": {"type": "object"},
    "performance": {
      "type": "object",
      "required": ["wall_time_seconds", "iterations_per_second", "peak_process_gpu_memory_mib"],
      "properties": {
        "wall_time_seconds": {"type": "number", "minimum": 0},
        "iterations_per_second": {"type": "number", "minimum": 0},
        "peak_process_gpu_memory_mib": {"type": "number", "minimum": 0}
      }
    },
    "artifact": {"type": ["object", "null"]},
    "quality": {"type": ["object", "null"]},
    "provenance": {"type": "object"}
  }
}
