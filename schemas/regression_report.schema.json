{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "3DGS Regression Report",
  "type": "object",
  "required": ["schema_version", "status", "thresholds", "regressions"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "status": {"type": "string", "enum": ["ok", "regression"]},
    "thresholds": {"type": "object"},
    "regressions": {"type": "array", "items": {"type": "object"}},
    "improvements": {"type": "array", "items": {"type": "object"}},
    "unchanged": {"type": "array", "items": {"type": "object"}}
  }
}

