{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Benchmark scene manifest",
  "type": "object",
  "required": ["schema_version", "scenes"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source", "status", "num_gaussians"],
        "properties": {
          "name": {"type": "string"},
          "source": {"type": "string"},
          "status": {"type": "string"},
          "num_gaussians": {"type": "integer", "minimum": 1},
          "model_path": {"type": "string"},
          "camera_path": {"type": "string"}
        }
      }
    }
  }
}
